---
import type { CollectionEntry } from 'astro:content';

interface Props {
  achievement: CollectionEntry<'achievements'>;
}

const { achievement } = Astro.props;
const { title, description, date, type, issuer, link, credential } = achievement.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'short',
});

const typeLabel: Record<string, string> = {
  cert:        'Certification',
  course:      'Course',
  award:       'Award',
  competition: 'Competition',
};
---

<article class="achievement-card">
  <div class="achievement-card__type-badge">
    {typeLabel[type] ?? type}
  </div>

  <h3 class="achievement-card__title">
    {link
      ? <a href={link} target="_blank" rel="noopener">{title}</a>
      : title
    }
  </h3>

  <p class="achievement-card__desc">{description}</p>

  <div class="achievement-card__meta">
    {issuer && <span class="achievement-card__issuer">{issuer}</span>}
    <time datetime={date.toISOString()} class="achievement-card__date">{formattedDate}</time>
  </div>

  {credential && (
    <p class="achievement-card__credential">
      <span class="achievement-card__cred-label">Credential ID</span>
      <code>{credential}</code>
    </p>
  )}
</article>

<style>
.achievement-card {
  background: var(--bg);
  border: 1px solid var(--rule-solid);
  border-radius: 6px;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.achievement-card:hover {
  border-color: var(--secondary);
  box-shadow: 0 4px 20px rgba(107, 63, 122, 0.07);
}

.achievement-card__type-badge {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--secondary);
  width: fit-content;
}

.achievement-card__title {
  font-size: var(--text-lg);
  font-weight: 600;
  line-height: 1.2;
  margin: 0;
}

.achievement-card__title a {
  color: var(--ink);
  text-decoration: none;
  transition: color 0.15s ease;
}

.achievement-card__title a:hover {
  color: var(--primary);
}

.achievement-card__desc {
  font-size: var(--text-sm);
  color: var(--ink-muted);
  line-height: 1.6;
  margin: 0;
}

.achievement-card__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: 0.25rem;
  flex-wrap: wrap;
}

.achievement-card__issuer {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--ink);
  font-family: var(--font-mono);
  letter-spacing: 0.03em;
}

.achievement-card__date {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--ink-muted);
  letter-spacing: 0.04em;
}

.achievement-card__issuer + .achievement-card__date::before {
  content: '·';
  margin-right: 0.75rem;
  color: var(--rule-solid);
}

.achievement-card__credential {
  font-size: var(--text-xs);
  color: var(--ink-muted);
  margin: 0;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.achievement-card__cred-label {
  font-family: var(--font-mono);
  letter-spacing: 0.04em;
}
</style>
