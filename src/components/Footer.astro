---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <span class="footer__copy">© {year} ardnyx</span>
    <span class="footer__sep" aria-hidden="true">✦</span>
    <nav class="footer__links" aria-label="Footer navigation">
      <a href="https://github.com/ardnyx" target="_blank" rel="noopener" class="footer__link">GitHub</a>
    </nav>
  </div>
</footer>

<style>
.footer {
  border-top: 1px solid var(--rule-solid);
  padding: 2rem 0;
  margin-top: auto;
}

.footer__inner {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.footer__copy {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--ink-muted);
  letter-spacing: 0.04em;
}

.footer__sep {
  font-size: 0.6rem;
  color: var(--accent);
}

.footer__links {
  display: flex;
  gap: 1.25rem;
}

.footer__link {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--ink-muted);
  text-decoration: none;
  letter-spacing: 0.04em;
  transition: color 0.15s ease;
}

.footer__link:hover {
  color: var(--primary);
}
</style>
