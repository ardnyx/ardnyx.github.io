---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, stack, tags, github, link, cover } = project.data;
---

<article class="project-card">
  {cover && (
    <a href={`/projects/${project.slug}`} class="project-card__cover-link" tabindex="-1" aria-hidden="true">
      <img
        src={cover}
        alt={title}
        class="project-card__cover"
        loading="lazy"
        decoding="async"
      />
    </a>
  )}

  <div class="project-card__body">
    <h3 class="project-card__title">
      <a href={`/projects/${project.slug}`}>{title}</a>
    </h3>
    <p class="project-card__desc">{description}</p>

    {stack.length > 0 && (
      <div class="project-card__stack">
        {stack.map(s => <span class="tag">{s}</span>)}
      </div>
    )}

    {tags.length > 0 && (
      <div class="project-card__tags">
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}

    <div class="project-card__links">
      {github && (
        <a href={github} class="project-card__link" target="_blank" rel="noopener">
          GitHub →
        </a>
      )}
      {link && (
        <a href={link} class="project-card__link project-card__link--primary" target="_blank" rel="noopener">
          Live →
        </a>
      )}
      <a href={`/projects/${project.slug}`} class="project-card__link">
        Read more →
      </a>
    </div>
  </div>
</article>

<style>
.project-card {
  background: var(--bg);
  border: 1px solid var(--rule-solid);
  border-radius: 6px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.project-card:hover {
  border-color: var(--secondary);
  box-shadow: 0 4px 20px rgba(107, 63, 122, 0.08);
}

.project-card__cover {
  width: 100%;
  height: 180px;
  object-fit: cover;
  display: block;
}

.project-card__cover-link {
  display: block;
  overflow: hidden;
}

.project-card__body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  flex: 1;
}

.project-card__title {
  font-size: var(--text-xl);
  font-weight: 600;
  line-height: 1.2;
}

.project-card__title a {
  color: var(--ink);
  text-decoration: none;
  transition: color 0.15s ease;
}

.project-card__title a:hover {
  color: var(--primary);
}

.project-card__desc {
  font-size: var(--text-sm);
  color: var(--ink-muted);
  line-height: 1.6;
  margin: 0;
  /* Clamp to 3 lines */
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.project-card__stack,
.project-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
}

.project-card__links {
  display: flex;
  gap: 1rem;
  align-items: center;
  margin-top: auto;
  padding-top: 0.5rem;
}

.project-card__link {
  font-size: var(--text-xs);
  font-weight: 500;
  font-family: var(--font-mono);
  color: var(--ink-muted);
  text-decoration: none;
  letter-spacing: 0.03em;
  transition: color 0.15s ease;
}

.project-card__link:hover {
  color: var(--primary);
}

.project-card__link--primary {
  color: var(--primary);
}
</style>
