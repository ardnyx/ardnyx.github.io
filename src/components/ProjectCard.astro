---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, stack, tags, github, link } = project.data;

// Hover-reveal images are parsed from the project body, in document order.
const bodyImages = [...project.body.matchAll(/!\[[^\]]*\]\(([^)\s]+)/g)].map(m => m[1]);
const hasMedia = bodyImages.length > 0;
const projectHref = `/projects/${project.slug}`;
---

<article class={`project-card${hasMedia ? ' project-card--has-media' : ''}`}>
  {hasMedia && (
    <div class="project-card__media" data-pc-media data-interval="1500" aria-hidden="true">
      <div class="project-card__media-stage">
        {bodyImages.map((src, i) => (
          <img
            src={src}
            alt=""
            class={`project-card__media-img${i === 0 ? ' is-active' : ''}`}
            data-pc-img
            data-gif={/\.gif(\?|#|$)/i.test(src) ? 'true' : 'false'}
            loading="lazy"
            decoding="async"
          />
        ))}
      </div>
      <div class="project-card__media-scrim"></div>
      <div class="project-card__media-cap">
        <h3 class="project-card__media-title">
          <a href={projectHref} tabindex="-1">{title}</a>
        </h3>
        <div class="project-card__media-links">
          {github && (
            <a href={github} target="_blank" rel="noopener" tabindex="-1">GitHub →</a>
          )}
          <a href={projectHref} tabindex="-1">Read more →</a>
        </div>
      </div>
    </div>
  )}

  <div class="project-card__body">
    <h3 class="project-card__title">
      <a href={projectHref}>{title}</a>
    </h3>
    <p class="project-card__desc">{description}</p>

    {stack.length > 0 && (
      <div class="project-card__stack">
        {stack.map(s => <span class="tag">{s}</span>)}
      </div>
    )}

    {tags.length > 0 && (
      <div class="project-card__tags">
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}

    <div class="project-card__links">
      {github && (
        <a href={github} class="project-card__link" target="_blank" rel="noopener">
          GitHub →
        </a>
      )}
      {link && (
        <a href={link} class="project-card__link project-card__link--primary" target="_blank" rel="noopener">
          Live →
        </a>
      )}
      <a href={projectHref} class="project-card__link">
        Read more →
      </a>
    </div>
  </div>
</article>

<style>
.project-card {
  position: relative;
  background: var(--bg);
  border: 1px solid var(--rule-solid);
  border-radius: 6px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.project-card:hover {
  border-color: var(--secondary);
  box-shadow: 0 4px 20px rgba(107, 63, 122, 0.08);
}

.project-card__body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  flex: 1;
}

.project-card__title {
  font-size: var(--text-xl);
  font-weight: 600;
  line-height: 1.2;
}

.project-card__title a {
  color: var(--ink);
  text-decoration: none;
  transition: color 0.15s ease;
}

.project-card__title a:hover {
  color: var(--primary);
}

.project-card__desc {
  font-size: var(--text-sm);
  color: var(--ink-muted);
  line-height: 1.6;
  margin: 0;
  /* Clamp to 3 lines */
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.project-card__stack,
.project-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
}

.project-card__links {
  display: flex;
  gap: 1rem;
  align-items: center;
  margin-top: auto;
  padding-top: 0.5rem;
}

.project-card__link {
  font-size: var(--text-xs);
  font-weight: 500;
  font-family: var(--font-mono);
  color: var(--ink-muted);
  text-decoration: none;
  letter-spacing: 0.03em;
  transition: color 0.15s ease;
}

.project-card__link:hover {
  color: var(--primary);
}

.project-card__link--primary {
  color: var(--primary);
}

/* ── Hover image reveal (desktop / hover-capable pointers only) ── */
.project-card__media {
  position: absolute;
  inset: 0;
  z-index: 2;
  opacity: 0;
  pointer-events: none;
  /* Hidden entirely unless a hover-capable device opts in below. */
  display: none;
  transition: opacity 0.3s ease;
}

.project-card__media-stage {
  position: absolute;
  inset: 0;
  background: var(--ink);
}

.project-card__media-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;        /* fill the frame, crop overflow, no empty bands */
  opacity: 0;
  transition: opacity 0.4s ease;
}

.project-card__media-img.is-active {
  opacity: 1;
}

/* Transparent over the image up top, darkening toward the caption. */
.project-card__media-scrim {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    transparent 42%,
    rgba(18, 12, 20, 0.55) 72%,
    rgba(18, 12, 20, 0.88) 100%
  );
  pointer-events: none;
}

.project-card__media-cap {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 1.25rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}

.project-card__media-title {
  font-size: var(--text-xl);
  font-weight: 600;
  line-height: 1.2;
  margin: 0;
}

.project-card__media-title a {
  color: #fff;
  text-decoration: none;
}

.project-card__media-links {
  display: flex;
  gap: 1rem;
  align-items: center;
}

.project-card__media-links a {
  font-size: var(--text-xs);
  font-weight: 500;
  font-family: var(--font-mono);
  color: #fff;
  text-decoration: none;
  letter-spacing: 0.03em;
  transition: opacity 0.15s ease;
}

.project-card__media-links a:hover {
  opacity: 0.75;
}

@media (hover: hover) and (pointer: fine) {
  .project-card--has-media .project-card__media {
    display: block;
  }

  .project-card--has-media:hover .project-card__media {
    opacity: 1;
    pointer-events: auto;
  }
}
</style>

<script>
  // ── GIF duration parsing ──────────────────────────────────
  // Sum the per-frame delays in a GIF so it can play exactly one loop
  // before the carousel advances. Results are cached per URL.
  const gifDurations = new Map<string, Promise<number>>();
  const FALLBACK_MS = 1500;

  function skipSubBlocks(buf: Uint8Array, i: number): number {
    let size = buf[i++];
    while (size !== 0 && i < buf.length) {
      i += size;
      size = buf[i++];
    }
    return i;
  }

  function parseGifDuration(buf: Uint8Array): number {
    let i = 6;                       // skip "GIF89a"
    const packed = buf[i + 4];
    const gctFlag = packed & 0x80;
    const gctSize = packed & 0x07;
    i += 7;
    if (gctFlag) i += 3 * (1 << (gctSize + 1));

    let totalCs = 0;                 // total delay in centiseconds
    while (i < buf.length) {
      const block = buf[i];
      if (block === 0x3b) break;     // trailer
      if (block === 0x21) {          // extension
        const label = buf[i + 1];
        i += 2;
        if (label === 0xf9) {        // graphic control extension
          totalCs += buf[i + 2] | (buf[i + 3] << 8);
        }
        i = skipSubBlocks(buf, i);
      } else if (block === 0x2c) {   // image descriptor
        const lpacked = buf[i + 9];
        i += 10;
        if (lpacked & 0x80) i += 3 * (1 << ((lpacked & 0x07) + 1));
        i += 1;                      // LZW minimum code size
        i = skipSubBlocks(buf, i);
      } else {
        break;                       // unexpected byte, bail safely
      }
    }
    const ms = totalCs * 10;
    return ms > 0 ? ms : FALLBACK_MS;
  }

  function gifDuration(url: string): Promise<number> {
    let p = gifDurations.get(url);
    if (!p) {
      p = fetch(url)
        .then(r => r.arrayBuffer())
        .then(b => parseGifDuration(new Uint8Array(b)))
        .catch(() => FALLBACK_MS);
      gifDurations.set(url, p);
    }
    return p;
  }

  // ── Per-card hover carousel ───────────────────────────────
  function initMedia(media: HTMLElement) {
    const imgs = Array.from(media.querySelectorAll<HTMLImageElement>('[data-pc-img]'));
    if (imgs.length === 0) return;

    const card = media.closest('.project-card') as HTMLElement;
    const base = Number(media.dataset.interval ?? '1500');
    let current = 0;
    let timer: number | undefined;
    let token = 0;                   // invalidates stale async scheduling

    // Pre-warm GIF durations so dwell times are ready on first hover.
    imgs.forEach(img => {
      if (img.dataset.gif === 'true') gifDuration(img.src);
    });

    function dwell(img: HTMLImageElement): Promise<number> {
      return img.dataset.gif === 'true' ? gifDuration(img.src) : Promise.resolve(base);
    }

    function show(idx: number) {
      current = (idx + imgs.length) % imgs.length;
      imgs.forEach((img, i) => img.classList.toggle('is-active', i === current));
    }

    async function scheduleNext(myToken: number) {
      if (imgs.length < 2) return;
      const ms = await dwell(imgs[current]);
      if (myToken !== token) return; // hover ended / restarted while awaiting
      timer = window.setTimeout(() => {
        if (myToken !== token) return;
        show(current + 1);
        scheduleNext(myToken);
      }, ms);
    }

    function start() {
      stop();
      token++;
      show(0);
      scheduleNext(token);
    }

    function stop() {
      token++;
      if (timer) { window.clearTimeout(timer); timer = undefined; }
    }

    card.addEventListener('mouseenter', start);
    card.addEventListener('mouseleave', stop);
  }

  document.querySelectorAll<HTMLElement>('[data-pc-media]').forEach(initMedia);
</script>
