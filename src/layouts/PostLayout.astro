---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title:        string;
  description:  string;
  date:         Date;
  tags?:        string[];
  readingTime?: string;
  category?:   'ctf' | 'malware';
  difficulty?:  string;
  event?:       string;
  stack?:       string[];
  github?:      string;
  link?:        string;
  backHref:     string;
  backLabel:    string;
}

const {
  title,
  description,
  date,
  tags = [],
  readingTime,
  category,
  difficulty,
  event,
  stack = [],
  github,
  link,
  backHref,
  backLabel,
} = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const difficultyColor: Record<string, string> = {
  easy:   '#2d6a4f',
  medium: '#b46b00',
  hard:   '#9b2335',
  insane: '#4a1a6b',
};
---

<BaseLayout title={`${title} — ardnyx`} description={description}>
  <article class="post">
    <div class="container">
      <nav class="post__back">
        <a href={backHref}>← {backLabel}</a>
      </nav>

      <header class="post__header">
        <div class="post__meta-top">
          {category && (
            <span class={`tag tag--${category}`}>
              {category === 'ctf' ? 'CTF' : 'Malware Analysis'}
            </span>
          )}
          {event && <span class="post__event">{event}</span>}
          {difficulty && (
            <span
              class="post__difficulty"
              style={`color: ${difficultyColor[difficulty] ?? 'inherit'}`}
            >
              {difficulty}
            </span>
          )}
        </div>

        <h1 class="post__title">{title}</h1>
        <p class="post__description">{description}</p>

        <div class="post__meta-bottom">
          <time datetime={date.toISOString()} class="post__date">{formattedDate}</time>
          {readingTime && <span class="post__reading-time">{readingTime}</span>}
        </div>

        {tags.length > 0 && (
          <div class="post__tags">
            {tags.map(t => <span class="tag">{t}</span>)}
          </div>
        )}

        {stack.length > 0 && (
          <div class="post__stack">
            {stack.map(s => <span class="tag">{s}</span>)}
          </div>
        )}

        {(github || link) && (
          <div class="post__links">
            {github && <a href={github} class="btn btn--ghost btn--sm" target="_blank" rel="noopener">GitHub →</a>}
            {link   && <a href={link}   class="btn btn--primary btn--sm" target="_blank" rel="noopener">Live →</a>}
          </div>
        )}
      </header>

      <div class="post__divider"></div>

      <div class="post__body prose-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
.post {
  padding: 3rem 0 5rem;
}

.post__back {
  margin-bottom: 2.5rem;
}

.post__back a {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--ink-muted);
  text-decoration: none;
  transition: color 0.15s ease;
}

.post__back a:hover {
  color: var(--primary);
}

.post__header {
  max-width: var(--container-prose);
  margin-bottom: 2.5rem;
}

.post__meta-top {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.25rem;
  flex-wrap: wrap;
}

.post__event {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--ink-muted);
  letter-spacing: 0.05em;
}

.post__difficulty {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.post__title {
  font-size: var(--text-4xl);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 1rem;
  letter-spacing: -0.02em;
}

.post__description {
  font-size: var(--text-lg);
  color: var(--ink-muted);
  line-height: 1.6;
  margin-bottom: 1.25rem;
}

.post__meta-bottom {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
}

.post__date {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--ink-muted);
  letter-spacing: 0.04em;
}

.post__reading-time {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--secondary);
  letter-spacing: 0.04em;
}

.post__reading-time::before {
  content: '·';
  margin-right: 1rem;
  color: var(--rule-solid);
}

.post__tags,
.post__stack {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-top: 0.75rem;
}

.post__links {
  display: flex;
  gap: 0.75rem;
  margin-top: 1.25rem;
  flex-wrap: wrap;
}

.post__divider {
  max-width: var(--container-prose);
  height: 1px;
  background: var(--rule-solid);
  margin-bottom: 2.5rem;
}

.post__body {
  max-width: var(--container-prose);
}

/* Prose content styles */
.post__body :global(h2) {
  font-size: var(--text-2xl);
  font-weight: 600;
  margin-top: 3rem;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--rule-solid);
}

.post__body :global(h3) {
  font-size: var(--text-xl);
  font-weight: 600;
  margin-top: 2rem;
  margin-bottom: 0.75rem;
}

.post__body :global(h4) {
  font-size: var(--text-lg);
  font-weight: 600;
  margin-top: 1.5rem;
  margin-bottom: 0.5rem;
}

.post__body :global(p) {
  margin-bottom: 1rem;
  line-height: 1.8;
}

.post__body :global(img) {
  border-radius: 6px;
  margin: 2rem auto;
  border: 1px solid var(--rule-solid);
}

.post__body :global(a) {
  color: var(--primary);
}

@media (max-width: 768px) {
  .post__title { font-size: var(--text-3xl); }
}
</style>
