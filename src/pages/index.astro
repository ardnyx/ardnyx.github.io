---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import WriteupCard from '../components/WriteupCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allWriteups = await getCollection('writeups');
const recentWriteups = allWriteups
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

// ── Achievements shown in the hero cycle ─────────────────────
// Image + overview are parsed out of each achievement's markdown body.

// HOW TO CUSTOMISE THE HERO ACHIEVEMENTS:
//  • To hand-pick exactly which achievements show (and in what order), list
//    their filenames (without the ".md") in HERO_ACHIEVEMENTS below, top = first.
//  • Leave the array empty ([]) to instead auto-show the most recent ones,
//    where HERO_CYCLE_COUNT controls how many.
const HERO_ACHIEVEMENTS: string[] = [
  'makati-ctf it skills olympics',
  'jissa-ctf hack the beat',
  'adu-ctf hackademic showdown copy',
];
const HERO_CYCLE_COUNT = 3;

const allAchievements = await getCollection('achievements');
const idOf = (e: typeof allAchievements[number]) => e.id.replace(/\.(md|mdx)$/i, '');

const selectedAchievements = HERO_ACHIEVEMENTS.length > 0
  ? HERO_ACHIEVEMENTS
      .map(id => allAchievements.find(a => idOf(a) === id))
      .filter((a): a is typeof allAchievements[number] => Boolean(a))
  : allAchievements
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
      .slice(0, HERO_CYCLE_COUNT);

function parseImage(body: string): string | null {
  const m = body.match(/!\[[^\]]*\]\(([^)\s]+)/);
  return m ? m[1] : null;
}

function parseOverview(body: string): string {
  // Grab everything after the first "## Overview" heading up to the next
  // image or heading, then collapse whitespace into a single paragraph.
  const m = body.match(/##\s*Overview\s*\r?\n+([\s\S]*?)(?:\r?\n!\[|\r?\n#{1,6}\s|$)/);
  const raw = m ? m[1] : body;
  return raw.replace(/\s+/g, ' ').trim();
}

const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });

const heroAchievements = await Promise.all(
  selectedAchievements.map(async (a) => {
    const { Content } = await a.render();
    return {
      title:    a.data.title,
      link:     a.data.link ?? '/achievements',
      issuer:   a.data.issuer,
      date:     a.data.date,
      image:    parseImage(a.body),
      overview: parseOverview(a.body),
      Content,                       // rendered markdown body for the modal
    };
  })
);
---

<BaseLayout title="ardnyx — Security Research, CTF, and Software Dev">

  <!-- ── Hero ─────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero__inner">
      <!-- Left: intro -->
      <div class="hero__main">
        <p class="hero__eyebrow">TW-PH | Computer Science | Information Engineering | </p>
        <h1 class="hero__title">
          Dann Leyesa<span class="hero__comma"> , </span><br />
          <em class="hero__sub-title">who are you?</em>
        </h1>
        <p class="hero__body">
          I write about CTF challenges, (soon) malware analysis, and other security research topics.
          I also share my personal projects, achievements, and experiments, in this portfolio-blog site. Feel free to connect with me!
        </p>
        <div class="hero__ctas">
          <a href="/projects"     class="btn btn--primary">View Projects</a>
          <a href="/writeups"     class="btn btn--ghost">Read Writeups</a>
        </div>
      </div>

      <!-- Right: cycling achievements -->
      {heroAchievements.length > 0 && (
        <div class="hero__showcase">
          <p class="hero__showcase-label">Achievements</p>
          <div class="cycle" data-cycle data-interval="3000">
            <div class="cycle__viewport">
              {heroAchievements.map((a, i) => (
                <article class={`cy-slide${i === 0 ? ' is-active' : ''}`} data-slide>
                  {a.image && (
                    <a class="cy-slide__img" href={a.link} target="_blank" rel="noopener">
                      <img src={a.image} alt={a.title} loading="lazy" />
                    </a>
                  )}
                  <div class="cy-slide__body">
                    <p class="cy-slide__overview" data-overview>{a.overview}</p>
                    <button class="cy-slide__more" type="button" data-more data-modal-target={`ach-modal-${i}`} hidden>
                      Read more…
                    </button>
                  </div>
                </article>
              ))}
            </div>

            <div class="cycle__controls">
              <button class="cycle__nav" data-prev aria-label="Previous achievement">←</button>
              <button class="cycle__nav" data-next aria-label="Next achievement">→</button>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ── Featured Projects ─────────────────────────────── -->
  {featuredProjects.length > 0 && (
    <section class="section">
      <div class="container">
        <p class="section-label">Featured Work</p>
        <div class="grid--projects">
          {featuredProjects.map(project => (
            <ProjectCard project={project} />
          ))}
        </div>
        <a href="/projects" class="view-all">All projects →</a>
      </div>
    </section>
  )}

  <!-- ── Recent Writeups ───────────────────────────────── -->
  {recentWriteups.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <p class="section-label">Featured Writeups</p>
        <div class="writeups-list" data-wu-fx>
          {recentWriteups.map(writeup => (
            <WriteupCard writeup={writeup} />
          ))}
        </div>
        <a href="/writeups" class="view-all">All writeups →</a>
      </div>
    </section>
  )}

  {recentWriteups.length > 0 && <canvas id="wu-fx" aria-hidden="true"></canvas>}

  <!-- ── Achievement detail modals ─────────────────────── -->
  {heroAchievements.map((a, i) => {
    const Body = a.Content;
    return (
      <div class="modal" id={`ach-modal-${i}`} data-modal hidden>
        <div class="modal__backdrop" data-modal-close></div>
        <div class="modal__dialog" role="dialog" aria-modal="true" aria-label={a.title}>
          <header class="modal__head">
            <h2 class="modal__title">{a.title}</h2>
            <p class="modal__meta">
              {a.issuer && <span class="modal__issuer">{a.issuer}</span>}
              <time datetime={a.date.toISOString()}>{fmtDate(a.date)}</time>
            </p>
          </header>
          <div class="modal__content">
            <Body />
          </div>
        </div>
      </div>
    );
  })}

  <!-- Gentle hint shown only while a modal is open -->
  <div class="esc-toast" data-esc-toast hidden aria-hidden="true">
    <span class="esc-toast__pill">Press <kbd>ESC</kbd> to close</span>
  </div>

</BaseLayout>

<style>
/* ── Hero ───────────────────────────────────────────────── */
.hero {
  padding: 6rem 0 5rem;
  border-bottom: 1px solid var(--rule-solid);
}

.hero__inner {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
  gap: 3.5rem;
  align-items: center;
}

.hero__main {
  min-width: 0;
}

.hero__eyebrow {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--secondary);
  margin-bottom: 1.5rem;
}

.hero__title {
  font-size: clamp(3rem, 7vw, 5.5rem);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 1.75rem;
  color: var(--ink);
}

.hero__comma {
  color: var(--primary);
}

.hero__sub-title {
  font-style: italic;
  font-weight: 300;
  color: var(--primary);
  /* Fraunces italic has lovely optical characteristics at large sizes */
  font-variation-settings: 'opsz' 144;
}

.hero__body {
  font-size: var(--text-lg);
  color: var(--ink-muted);
  max-width: 58ch;
  line-height: 1.7;
  margin-bottom: 2.25rem;
}

.hero__ctas {
  display: flex;
  gap: 0.875rem;
  flex-wrap: wrap;
}

/* ── Hero achievement cycle ─────────────────────────────── */
.hero__showcase {
  min-width: 0;
}

.hero__showcase-label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--secondary);
  margin-bottom: 1rem;
}

.cycle {
  position: relative;
  border: 1px solid var(--rule-solid);
  border-radius: 8px;
  overflow: hidden;
  background: var(--bg);
}

.cycle__viewport {
  display: grid;
}

.cy-slide {
  grid-area: 1 / 1;            /* stack all slides in one cell */
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.5s ease;
  display: flex;
  flex-direction: column;
}

.cy-slide.is-active {
  opacity: 1;
  visibility: visible;
}

.cy-slide__img {
  display: block;
  line-height: 0;
}

.cy-slide__img img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  display: block;
}

.cy-slide__body {
  position: relative;
  padding: 1.25rem 1.5rem 1.5rem;
  flex: 1;
}

.cy-slide__overview {
  font-size: var(--text-sm);
  color: var(--ink-muted);
  line-height: 1.65;
  margin: 0;
}

/* Clamp + fade applied only when the text actually overflows. */
.cy-slide__overview.is-clamped {
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
  -webkit-mask-image: linear-gradient(to bottom, #000 60%, transparent 100%);
          mask-image: linear-gradient(to bottom, #000 60%, transparent 100%);
}

.cy-slide__more {
  display: inline-block;
  margin-top: 0.65rem;
  padding: 0;
  border: none;
  background: none;
  cursor: pointer;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.04em;
  color: var(--primary);
  text-decoration: none;
}

.cy-slide__more:hover {
  text-decoration: underline;
}

.cycle__controls {
  position: absolute;
  top: 200px;                  /* sit over the image's bottom edge */
  right: 0.75rem;
  transform: translateY(-50%);
  display: flex;
  gap: 0.4rem;
}

.cycle__nav {
  width: 2rem;
  height: 2rem;
  display: grid;
  place-items: center;
  border: 1px solid var(--rule-solid);
  border-radius: 50%;
  background: var(--bg);
  color: var(--ink);
  font-size: 0.95rem;
  line-height: 1;
  cursor: pointer;
  transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
}

.cycle__nav:hover {
  border-color: var(--secondary);
  color: var(--primary);
}

/* ── Writeups list ──────────────────────────────────────── */
.writeups-list {
  border-top: 1px solid var(--rule-solid);
}

@media (max-width: 860px) {
  .hero__inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .hero__showcase {
    max-width: 480px;
  }
}

@media (max-width: 640px) {
  .hero { padding: 3.5rem 0 3rem; }
}

/* ── Achievement modal ──────────────────────────────────── */
.modal[hidden] { display: none; }

.modal {
  position: fixed;
  inset: 0;
  z-index: 1000;          /* above the writeup cloud overlay (150) */
  display: grid;
  place-items: center;
  padding: 1.5rem;
}

.modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(20, 12, 24, 0.55);
  -webkit-backdrop-filter: blur(4px);
          backdrop-filter: blur(4px);
}

.modal__dialog {
  position: relative;
  z-index: 1;
  width: min(680px, 100%);
  max-height: 85vh;
  overflow-y: auto;
  background: var(--bg);
  border: 1px solid var(--rule-solid);
  border-radius: 12px;
  padding: 2rem 2.25rem 2.25rem;
  box-shadow: 0 24px 60px rgba(20, 12, 24, 0.28);
  animation: modal-rise 0.28s ease both;
}

@keyframes modal-rise {
  from { opacity: 0; transform: translateY(12px) scale(0.98); }
  to   { opacity: 1; transform: translateY(0)    scale(1); }
}

.modal__head {
  margin-bottom: 1.25rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--rule-solid);
}

.modal__title {
  font-size: var(--text-2xl, 1.6rem);
  font-weight: 700;
  line-height: 1.2;
  margin: 0 0 0.5rem;
  color: var(--ink);
}

.modal__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin: 0;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--ink-muted);
}

.modal__issuer {
  font-weight: 600;
  color: var(--ink);
}

.modal__issuer + time::before {
  content: '·';
  margin-right: 0.75rem;
  color: var(--rule-solid);
}

/* Rendered markdown body */
.modal__content :global(img) {
  max-width: 100%;
  height: auto;
  border-radius: 8px;
  margin: 1.25rem 0;
}

.modal__content :global(h1),
.modal__content :global(h2),
.modal__content :global(h3) {
  margin: 1.5rem 0 0.75rem;
  line-height: 1.25;
}

.modal__content :global(p) {
  margin: 0 0 1rem;
  line-height: 1.7;
  color: var(--ink-muted);
}

.modal__content :global(ul),
.modal__content :global(ol) {
  margin: 0 0 1rem 1.25rem;
  line-height: 1.7;
  color: var(--ink-muted);
}

body.modal-open { overflow: hidden; }

/* ── "Press ESC to close" hint ──────────────────────────── */
.esc-toast[hidden] { display: none; }

.esc-toast {
  position: fixed;
  left: 50%;
  bottom: 1.5rem;
  z-index: 1010;                 /* above modal (1000) and cloud (150) */
  pointer-events: none;          /* never blocks reading or clicks */
  transform: translateX(-50%);
}

.esc-toast__pill {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.45rem 0.9rem;
  border-radius: 999px;
  background: color-mix(in srgb, var(--primary) 90%, black);
  color: #fff;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.04em;
  box-shadow: 0 6px 20px rgba(20, 12, 24, 0.25);
  animation:
    esc-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both,
    esc-bob 2.4s ease-in-out 0.5s infinite;
}

.esc-toast kbd {
  font-family: var(--font-mono);
  font-size: 0.9em;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 4px;
  padding: 0.05em 0.4em;
}

@keyframes esc-pop {
  from { opacity: 0; transform: translateY(14px) scale(0.85); }
  to   { opacity: 1; transform: translateY(0)    scale(1); }
}

@keyframes esc-bob {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-4px); }
}

@media (prefers-reduced-motion: reduce) {
  .modal__dialog,
  .esc-toast__pill { animation: none; }
}

/* ── Writeup hover FX (cloud vignette + insane text corruption) ── */
#wu-fx {
  position: fixed;
  inset: 0;
  z-index: 150;           /* above the sticky nav (100) so the cloud covers it too */
  pointer-events: none;
  display: none;          /* enabled by JS only on hover-capable devices */
}

.writeup-card .ch { display: inline; }
.writeup-card .ch.corrupt {
  color: #d8362a;
  text-shadow: 0 0 7px rgba(216, 54, 42, 0.85);
}
.writeup-card .ch.shine {
  color: #ffe7a0;
  text-shadow: 0 0 8px rgba(255, 205, 110, 0.95), 0 0 17px rgba(255, 170, 70, 0.55);
  animation: wu-shine 0.6s ease;
}
@keyframes wu-shine {
  0%   { filter: brightness(1); }
  35%  { filter: brightness(2.4); }
  100% { filter: brightness(1); }
}
</style>

<script>
  function initCycle(root: HTMLElement) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
    if (slides.length === 0) return;

    const interval = Number(root.dataset.interval ?? '3000');
    let current = slides.findIndex(s => s.classList.contains('is-active'));
    if (current < 0) current = 0;
    let timer: number | undefined;

    // Show "Read more" + fade only when the overview overflows its clamp.
    function applyClamp(slide: HTMLElement) {
      const overview = slide.querySelector<HTMLElement>('[data-overview]');
      const more = slide.querySelector<HTMLElement>('[data-more]');
      if (!overview) return;
      overview.classList.add('is-clamped');
      const overflowing = overview.scrollHeight > overview.clientHeight + 1;
      if (!overflowing) overview.classList.remove('is-clamped');
      if (more) more.hidden = !overflowing;
    }

    function show(next: number) {
      current = (next + slides.length) % slides.length;
      slides.forEach((s, i) => s.classList.toggle('is-active', i === current));
    }

    function start() {
      stop();
      if (slides.length > 1) timer = window.setInterval(() => show(current + 1), interval);
    }
    function stop() {
      if (timer) { window.clearInterval(timer); timer = undefined; }
    }

    root.querySelector('[data-next]')?.addEventListener('click', () => { show(current + 1); start(); });
    root.querySelector('[data-prev]')?.addEventListener('click', () => { show(current - 1); start(); });

    // Pause while interacting so a manual override isn't yanked away.
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    // Measure each slide once layout is ready.
    slides.forEach(applyClamp);
    show(current);
    start();
  }

  document.querySelectorAll<HTMLElement>('[data-cycle]').forEach(initCycle);

  // ── Achievement modals ────────────────────────────────────
  (function initModals() {
    const toast = document.querySelector<HTMLElement>('[data-esc-toast]');
    let open: HTMLElement | null = null;

    function showModal(modal: HTMLElement) {
      open = modal;
      modal.hidden = false;
      document.body.classList.add('modal-open');
      if (toast) toast.hidden = false;
    }

    function hideModal() {
      if (!open) return;
      open.hidden = true;
      open = null;
      document.body.classList.remove('modal-open');
      if (toast) toast.hidden = true;
    }

    document.querySelectorAll<HTMLElement>('[data-modal-target]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-modal-target');
        const modal = id ? document.getElementById(id) : null;
        if (modal) showModal(modal);
      });
    });

    // Click on the darkened/blurred backdrop closes the modal.
    document.querySelectorAll<HTMLElement>('[data-modal-close]').forEach(el => {
      el.addEventListener('click', hideModal);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) hideModal();
    });
  })();
</script>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('wu-fx');
  const list = document.querySelector('[data-wu-fx]');
  const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  if (canvas && list && canHover) {
    const MOTION = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    canvas.style.display = 'block';

    const FX = {
      medium: { tint:[1.00,0.72,0.30], dark:[0.055,0.040,0.050], veil:0.52, tintAmt:0.60, hint:0.00,
                inner:45, outer:640, core:0.00, floor:0.30, through:0.30, irr:0.13, gusty:false },
      hard:   { tint:[0.88,0.20,0.12], dark:[0.055,0.022,0.024], veil:0.78, tintAmt:0.62, hint:0.05,
                inner:40, outer:560, core:0.07, floor:0.46, through:0.36, irr:0.18, gusty:false },
      insane: { tint:[0.40,0.055,0.05], dark:[0.016,0.007,0.010], veil:1.00, tintAmt:0.55, hint:0.12,
                inner:30, outer:500, core:0.17, floor:0.90, through:0.60, irr:0.27, gusty:true }
    };

    const frag = `
      precision highp float;
      uniform vec2 uRes; uniform vec2 uMouse; uniform float uPhase; uniform float uWind;
      uniform float uActive; uniform float uVeil; uniform float uTintAmt; uniform float uHint;
      uniform float uInner; uniform float uOuter; uniform float uCore; uniform float uFloor;
      uniform float uThrough; uniform float uIrr; uniform vec3 uTint; uniform vec3 uDark;
      float hash(vec2 p){ return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453); }
      float noise(vec2 p){ vec2 i=floor(p),f=fract(p);
        float a=hash(i),b=hash(i+vec2(1.,0.)),c=hash(i+vec2(0.,1.)),d=hash(i+vec2(1.,1.));
        vec2 u=f*f*(3.-2.*f); return mix(mix(a,b,u.x),mix(c,d,u.x),u.y); }
      float fbm(vec2 p){ float v=0.,a=0.5; for(int i=0;i<5;i++){ v+=a*noise(p); p*=2.02; a*=0.5; } return v; }
      void main(){
        vec2 uv = gl_FragCoord.xy/uRes;
        vec2 muv = vec2(uMouse.x, uRes.y-uMouse.y)/uRes;
        float aspect = uRes.x/uRes.y;
        float dist = length(vec2((uv.x-muv.x)*aspect, uv.y-muv.y));
        float t = uPhase;
        vec2 p = vec2(uv.x*aspect, uv.y)*3.0;
        float warp = fbm(p*0.6 - vec2(t*0.7, t));
        float warp2 = fbm(p*1.5 + vec2(-t*1.4, t*0.9));
        float cloud = fbm(p + vec2(t, t*0.5) + warp*(0.7 + uWind*0.6) + warp2*(0.25 + uWind*0.4));
        cloud = clamp(cloud, 0.0, 1.0);
        float edge = dist + (warp-0.5)*uIrr + (warp2-0.5)*uIrr*0.6;
        float ramp = smoothstep(uInner/uRes.y, uOuter/uRes.y, edge);
        float vig = mix(uCore, 1.0, ramp);
        float through = (1.0-ramp) * smoothstep(0.48,0.92,cloud) * uThrough * (0.7 + uWind*0.6);
        vec3 col = mix(uDark, uTint, cloud*uTintAmt);
        col = mix(col, vec3(1.0,0.82,0.32), smoothstep(0.74,1.0,cloud)*uHint);
        float dens = uFloor + (1.0-uFloor)*cloud;
        float alpha = uActive * uVeil * (vig*dens + through);
        gl_FragColor = vec4(col, clamp(alpha,0.0,1.0));
      }`;
    const vert = 'void main(){ gl_Position = vec4(position.xy,0.0,1.0); }';

    const renderer = new THREE.WebGLRenderer({ canvas, alpha:true, antialias:true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    const scene = new THREE.Scene();
    const camera = new THREE.Camera();

    const U = {
      uRes:{value:new THREE.Vector2()}, uMouse:{value:new THREE.Vector2(-9999,-9999)},
      uPhase:{value:0}, uWind:{value:1}, uActive:{value:0}, uVeil:{value:0.6}, uTintAmt:{value:0.6},
      uHint:{value:0}, uInner:{value:150}, uOuter:{value:620}, uCore:{value:0}, uFloor:{value:0.3},
      uThrough:{value:0.22}, uIrr:{value:0.12},
      uTint:{value:new THREE.Color(1,0.72,0.3)}, uDark:{value:new THREE.Color(0.05,0.04,0.05)}
    };
    const mat = new THREE.ShaderMaterial({ uniforms:U, vertexShader:vert, fragmentShader:frag, transparent:true });
    scene.add(new THREE.Mesh(new THREE.PlaneGeometry(2,2), mat));

    function resize(){
      const w = window.innerWidth, h = window.innerHeight;
      renderer.setSize(w, h, false);
      U.uRes.value.set(w*renderer.getPixelRatio(), h*renderer.getPixelRatio());
    }
    window.addEventListener('resize', resize); resize();

    const tgtMouse = { x:-9999, y:-9999 };
    const tgt = { active:0, veil:0.6, tintAmt:0.6, hint:0, inner:150, outer:620, core:0, floor:0.3,
                  through:0.22, irr:0.12, tint:new THREE.Color(1,0.72,0.3), dark:new THREE.Color(0.05,0.04,0.05) };
    let gusty = false;

    function setDiff(d){
      const f = FX[d]; if (!f) return;
      tgt.tint.setRGB(f.tint[0],f.tint[1],f.tint[2]);
      tgt.dark.setRGB(f.dark[0],f.dark[1],f.dark[2]);
      tgt.veil=f.veil; tgt.tintAmt=f.tintAmt; tgt.hint=f.hint;
      tgt.inner=f.inner; tgt.outer=f.outer; tgt.core=f.core; tgt.floor=f.floor;
      tgt.through=f.through; tgt.irr=f.irr; gusty=f.gusty;
    }

    document.addEventListener('mousemove', (e) => {
      tgtMouse.x = e.clientX*renderer.getPixelRatio();
      tgtMouse.y = e.clientY*renderer.getPixelRatio();
    });

    // ── insane text corruption + shine ──
    const GLYPHS = '日ﾊﾐﾋｰｳｼﾅﾓﾆﾔﾇﾈ012789#%&$@/<>*+=≡≠█▓░'.split('');
    const randGlyph = () => GLYPHS[(Math.random()*GLYPHS.length)|0];
    let cTimer = null, cEls = null;

    function wrapChars(el){
      if (el.dataset.wrapped) return;
      const text = el.textContent; el.textContent=''; el.dataset.wrapped='1';
      for (let i=0;i<text.length;i++){
        const s = document.createElement('span');
        s.className='ch'; s.textContent=text[i]; s.dataset.ch=text[i];
        el.appendChild(s);
      }
    }
    function unwrapChars(el){
      if (!el.dataset.wrapped) return;
      let t=''; el.querySelectorAll('.ch').forEach(s => { t+=s.dataset.ch; });
      el.textContent=t; delete el.dataset.wrapped;
    }
    function corruptChar(s){
      if (s.dataset.busy) return; s.dataset.busy='1'; s.classList.add('corrupt');
      let flips=2+((Math.random()*3)|0), fi=0;
      const iv = setInterval(() => {
        s.textContent = randGlyph();
        if (++fi>=flips){ clearInterval(iv);
          setTimeout(() => { s.textContent=s.dataset.ch; s.classList.remove('corrupt'); delete s.dataset.busy; },
            70+Math.random()*140);
        }
      }, 55);
    }
    function shineChar(s){ s.classList.add('shine'); setTimeout(() => s.classList.remove('shine'), 620); }
    function startCorruption(card){
      if (!MOTION) return;
      stopCorruption();
      cEls = [card.querySelector('.writeup-card__title a'), card.querySelector('.writeup-card__desc')].filter(Boolean);
      cEls.forEach(wrapChars);
      const chars = [];
      cEls.forEach(el => el.querySelectorAll('.ch').forEach(s => { if (s.dataset.ch!==' ') chars.push(s); }));
      if (!chars.length) return;
      cTimer = setInterval(() => {
        const n = 1+((Math.random()*2)|0);
        for (let i=0;i<n;i++){ if (Math.random()<0.9) corruptChar(chars[(Math.random()*chars.length)|0]); }
        if (Math.random()<0.55) shineChar(chars[(Math.random()*chars.length)|0]);
      }, 130);
    }
    function stopCorruption(){
      if (cTimer){ clearInterval(cTimer); cTimer=null; }
      if (cEls){ cEls.forEach(el => {
        el.querySelectorAll('.ch').forEach(s => { s.textContent=s.dataset.ch; s.className='ch'; delete s.dataset.busy; });
        unwrapChars(el);
      }); cEls=null; }
    }

    list.querySelectorAll('.writeup-card').forEach(card => {
      card.addEventListener('mouseenter', () => {
        const d = card.dataset.difficulty;
        stopCorruption();
        if (!FX[d]) { tgt.active = 0; return; }   // easy / none → nothing
        setDiff(d); tgt.active = 1; ensureLoop();
        if (d === 'insane') startCorruption(card);
      });
    });
    list.addEventListener('mouseleave', () => { tgt.active = 0; stopCorruption(); });

    // ── wind gusts (insane) ──
    const k = (dt,tau) => 1-Math.exp(-dt/tau);
    let windPhase=0, wind=1, windTarget=1, windTimer=0;
    function stepWind(dt){
      if (!MOTION){ wind=0; return; }
      windTimer -= dt;
      if (windTimer<=0){
        windTimer = 1.4 + Math.random()*3.4;
        windTarget = gusty
          ? (Math.random()<0.32 ? 0.20+Math.random()*0.30 : 0.9+Math.random()*2.2)
          : 0.85 + Math.random()*0.4;
      }
      wind += (windTarget-wind)*k(dt,0.9);
      windPhase += dt*wind*0.03;
    }

    // ── loop with idle pause ──
    let running=false, last=0;
    function ensureLoop(){ if (!running){ running=true; last=performance.now(); requestAnimationFrame(loop); } }
    function loop(now){
      const dt = Math.min((now-last)/1000, 0.1); last=now;
      stepWind(dt);
      const km=k(dt,0.10), kc=k(dt,0.45), ka=k(dt,0.50);
      if (U.uMouse.value.x<-9000) U.uMouse.value.set(tgtMouse.x, tgtMouse.y);
      U.uMouse.value.x += (tgtMouse.x-U.uMouse.value.x)*km;
      U.uMouse.value.y += (tgtMouse.y-U.uMouse.value.y)*km;
      U.uPhase.value = windPhase;
      U.uWind.value += (wind-U.uWind.value)*k(dt,0.6);
      U.uActive.value += (tgt.active-U.uActive.value)*ka;
      U.uVeil.value += (tgt.veil-U.uVeil.value)*kc;
      U.uTintAmt.value += (tgt.tintAmt-U.uTintAmt.value)*kc;
      U.uHint.value += (tgt.hint-U.uHint.value)*kc;
      U.uInner.value += (tgt.inner-U.uInner.value)*kc;
      U.uOuter.value += (tgt.outer-U.uOuter.value)*kc;
      U.uCore.value += (tgt.core-U.uCore.value)*kc;
      U.uFloor.value += (tgt.floor-U.uFloor.value)*kc;
      U.uThrough.value += (tgt.through-U.uThrough.value)*kc;
      U.uIrr.value += (tgt.irr-U.uIrr.value)*kc;
      U.uTint.value.lerp(tgt.tint, kc);
      U.uDark.value.lerp(tgt.dark, kc);
      renderer.render(scene, camera);
      if (tgt.active===0 && U.uActive.value<0.004){ running=false; return; }  // idle: stop rendering
      requestAnimationFrame(loop);
    }
  }
</script>
